PORT=3000
DISCORD_WEBHOOK_URL=
===============================================================
TOKEN= <------- โทเค่นบอท Discord ของคุณ
CLIENT_ID= <------- ไอดีของบอท Discord ของคุณ
STARTUP_CHANNEL=<------- ไอดีของช่อง Discord ที่บอทจะส่งข้อความเมื่อเริ่มต้น
GUILD_ID=<------- ไอดีของเซิร์ฟเวอร์ Discord ของคุณ
ALERT_CHANNEL=<----- -- ไอดีของช่อง Discord ที่บอทจะส่งข้อความแจ้งเตือนเมื่อมีการแจ้งเตือนเกิดขึ้น
WEATHER_CHANNEL=<------- ไอดีของช่อง Discord ที่บอทจะส่งข้อความเกี่ยวกับสภาพอากาศ
===============================================================
GEMINI_API_KEY=<------- คีย์ API ของ Gemini ของคุณ
===============================================================
TELEGRAM_TOKEN=<------- โทเค่นบอท Telegram ของคุณ
TELEGRAM_CHAT_ID=-<------- ไอดีแชท Telegram ที่บอทจะส่งข้อความ
===============================================================